<!DOCTYPE html>
<html lang="en">

<head>
  <link rel="shortcut icon" href="/images/tech_riders_logo.jpg" type="image/x-icon">
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AyuLinker Chatbot</title>
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
  <script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
  <style>
    :root {
      --primary-blue: #3b82f6;
      --secondary-blue: #60a5fa;
      --accent-cyan: #06b6d4;
      --success-green: #10b981;
      --warning-orange: #f59e0b;
      --error-red: #ef4444;

      /* Text Colors */
      --text-primary: #1f2937;
      --text-secondary: #6b7280;
      --text-muted: #9ca3af;
      --text-light: #d1d5db;

      /* Background Colors */
      --bg-primary: #ffffff;
      --bg-secondary: #f8fafc;
      --bg-tertiary: #f1f5f9;
      --bg-accent: #e0f2fe;

      /* Border and Shadow */
      --border-light: #e5e7eb;
      --border-medium: #d1d5db;
      --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1),
        0 2px 4px -1px rgba(0, 0, 0, 0.06);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1),
        0 4px 6px -2px rgba(0, 0, 0, 0.05);
      --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1),
        0 10px 10px -5px rgba(0, 0, 0, 0.04);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      color: var(--text-primary);
    }

    /* Main content */
    .main-content {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 2rem;
      margin-top: 70px;
    }

    /* Chat container */
    .chat-container {
      width: 100%;
      max-width: 800px;
      height: 600px;
      background: var(--bg-primary);
      border-radius: 20px;
      box-shadow: var(--shadow-xl);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .chat-header {
      background: linear-gradient(135deg,
          var(--primary-blue),
          var(--secondary-blue));
      color: #fff;
      padding: 20px;
      font-size: 18px;
      font-weight: 600;
      text-align: center;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }

    .chatbox {
      flex: 1;
      padding: 20px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      background: var(--bg-secondary);
      gap: 12px;
    }

    .msg {
      max-width: 75%;
      padding: 14px 18px;
      border-radius: 18px;
      position: relative;
      line-height: 1.5;
      font-size: 0.95rem;
      word-wrap: break-word;
      white-space: pre-line;
      box-shadow: var(--shadow-sm);
    }

    .bot {
      background: var(--bg-primary);
      align-self: flex-start;
      border: 1px solid var(--border-light);
      border-bottom-left-radius: 4px;
    }

    .user {
      background: var(--success-green);
      color: #fff;
      align-self: flex-end;
      border-bottom-right-radius: 4px;
    }

    .timestamp {
      font-size: 10px;
      color: var(--text-muted);
      margin-top: 4px;
      display: block;
      text-align: right;
    }

    .input-area {
      display: flex;
      padding: 16px;
      border-top: 1px solid var(--border-light);
      background: var(--bg-primary);
    }

    #message {
      flex: 1;
      padding: 12px 16px;
      border-radius: 12px;
      border: 1px solid var(--border-medium);
      font-size: 14px;
      outline: none;
      transition: all 0.2s;
    }

    #message:focus {
      border-color: var(--primary-blue);
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
    }

    button {
      margin-left: 12px;
      padding: 12px 20px;
      border: none;
      background: linear-gradient(135deg,
          var(--primary-blue),
          var(--secondary-blue));
      color: #fff;
      border-radius: 12px;
      cursor: pointer;
      font-weight: 500;
      transition: transform 0.2s, box-shadow 0.2s;
    }

    button:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    /* Reset button specific styles */
    #resetButton {
      background: linear-gradient(135deg,
          var(--warning-orange),
          #fbbf24);
      padding: 12px 16px;
    }

    /* Typing indicator */
    .typing {
      display: none;
      align-self: flex-start;
      background: var(--bg-primary);
      padding: 12px 18px;
      border-radius: 18px;
      margin: 4px 0;
      font-size: 14px;
      color: var(--text-secondary);
      border: 1px solid var(--border-light);
      box-shadow: var(--shadow-sm);
    }

    .dots span {
      animation: blink 1.5s infinite;
      font-size: 18px;
      margin: 0 2px;
    }

    .dots span:nth-child(2) {
      animation-delay: 0.2s;
    }

    .dots span:nth-child(3) {
      animation-delay: 0.4s;
    }

    /* Footer */
    .footer {
      background: var(--text-primary);
      color: white;
      padding: 2rem 0;
      text-align: center;
    }

    .google-btn {
      display: inline-block;
      margin-left: 6px;
      padding: 2px 8px;
      background: #3b82f6;
      color: white;
      border-radius: 4px;
      font-size: 12px;
      text-decoration: none;
    }

    .google-btn:hover {
      background: #2563eb;
    }


    @keyframes blink {
      0% {
        opacity: 0.2;
      }

      20% {
        opacity: 1;
      }

      100% {
        opacity: 0.2;
      }
    }

    /* Responsive adjustments */
    @media (max-width: 768px) {

      .main-content {
        padding: 1rem;
        margin-top: 70px;
      }

      .chat-container {
        height: 80vh;
      }

      .msg {
        max-width: 85%;
      }

      /* Stack buttons on mobile */
      .input-area {
        flex-wrap: wrap;
      }

      .input-area button {
        margin-top: 8px;
        flex: 1;
      }

      #message {
        min-width: 100%;
      }
    }


    @media (max-width: 1024px) {
      .faq-3d {
        max-width: 25rem;
        height: 30rem;
      }
    }

    @media (max-width: 768px) {
      .faq-3d {
        max-width: 20rem;
        height: 22rem;
      }
    }

    /* Mobile landscape */
    @media (max-width: 768px) and (orientation: landscape) {
      .faq-3d {
        max-width: 18rem;
        height: 18rem;
      }
    }

    /* Tablets: tighten layout and scale fonts */
    @media (max-width: 992px) {
      .chat-container {
        max-width: 90%;
        height: 75vh;
      }

      .chat-header {
        font-size: 1rem;
        padding: 16px;
      }
    }

    /* Phones: full-width chat and stacked controls */
    @media (max-width: 768px) {
      .chat-container {
        max-width: 100%;
        height: 80vh;
        border-radius: 16px;
      }

      .chatbox {
        padding: 14px;
        gap: 10px;
      }

      .msg {
        max-width: 90%;
        font-size: 0.9rem;
        padding: 12px 16px;
      }

      .input-area {
        flex-direction: column;
        gap: 10px;
        padding: 12px;
      }

      #message,
      .input-area button {
        width: 100%;
      }

      button {
        font-size: 0.9rem;
        padding: 10px 16px;
      }
    }

    .user .timestamp {
      color: white;
    }

    /* Very small phones */
    @media (max-width: 480px) {
      .chat-container {
        height: 75vh;
        border-radius: 12px;
      }

      .chat-header {
        font-size: 0.95rem;
        padding: 12px;
      }

      .msg {
        font-size: 0.85rem;
        padding: 10px 14px;
      }

      #message {
        font-size: 0.9rem;
      }
    }

    /* Landscape small height */
    @media (max-height: 420px) and (orientation: landscape) {
      .chat-container {
        height: 90vh;
      }

      .chatbox {
        padding: 10px;
      }
    }
  </style>
</head>

<body>
  <%- include("navbar") %>

    <!-- Main Content -->
    <div class="main-content">
      <!-- Chat UI -->
      <div class="chat-container">
        <div class="chat-header">
          <span>🩺 AyuLinker Chatbot</span>
        </div>
        <div class="chatbox" id="chat"></div>

        <!-- Typing indicator -->
        <div class="typing" id="typing">
          <div class="dots"><span>•</span><span>•</span><span>•</span></div>
        </div>

        <div class="input-area">
          <input type="text" id="message" placeholder="Type your symptom..."
            onkeypress="if(event.key==='Enter'){sendMsg()}" />
          <button onclick="sendMsg()">Send</button>
          <button id="resetButton" onclick="resetChat()">Reset</button>
        </div>
      </div>
    </div>


    <!-- Footer -->
    <%- include('footer') %>



      <script>
        let sessionId = Date.now().toString();

        function addMsg(text, cls) {
          const d = document.createElement("div");
          d.className = "msg " + cls;
          const time = new Date().toLocaleTimeString([], {
            hour: "2-digit",
            minute: "2-digit",
          });

          // Directly inject text as HTML
          d.innerHTML = `<div>${text}</div><span class="timestamp">${time}</span>`;

          const chatBox = document.getElementById("chat");
          chatBox.appendChild(d);
          chatBox.scrollTop = chatBox.scrollHeight;
        }

        async function sendMsg() {
          const input = document.getElementById("message");
          const msg = input.value.trim();
          if (!msg) return;

          addMsg(msg, "user");
          input.value = "";

          // Show typing dots
          document.getElementById("typing").style.display = "block";

          try {
            const r = await fetch("/chat/message", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ sessionId, message: msg }),
            });
            const j = await r.json();

            // Hide typing dots
            document.getElementById("typing").style.display = "none";

            addMsg(j.reply, "bot");
          } catch (error) {
            document.getElementById("typing").style.display = "none";
            addMsg("⚠️ Sorry, I'm having trouble connecting right now. Please try again later.", "bot");
            console.error("Error:", error);
          }
        }

        // Reset chat function
        function resetChat() {
          if (confirm("Are you sure you want to reset the conversation?")) {
            document.getElementById("chat").innerHTML = '';
            sessionId = Date.now().toString();
            addMsg("👋 Welcome! I'm AyuLinker Chatbot.<br>Please tell me your symptoms like <strong>I am facing fever</strong> or <strong>jaundice</strong>.", "bot");
            document.getElementById("message").focus();
          }
        }

        window.onload = () => {
          addMsg("👋 Welcome! I'm AyuLinker Chatbot.<br>Please tell me your symptoms like <strong>I am facing fever</strong> or <strong>jaundice</strong>.", "bot");
          document.getElementById("message").focus();
        };
      </script>
</body>

</html>