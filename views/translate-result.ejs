<!DOCTYPE html>
<html>
<head>
  <title>Translation Result</title>
  <link rel="stylesheet" href="/css/translate-result.css">
  <link rel="shortcut icon" href="/images/tech_riders_logo.jpg" type="image/x-icon">
  <style>
    html, body {
      height: 100%;
      margin: 0;
      display: flex;
      flex-direction: column;
      font-family: Arial, sans-serif;
    }
    .container {
      flex: 1;
      padding: 2rem;
    }
    .message {
      margin: 1rem 0;
      padding: 0.8rem;
      border-radius: 6px;
      font-weight: 500;
    }
    .message.success { background-color: #e9f7ef; color: #256029; border: 1px solid #b6dfb9; }
    .message.info { background-color: #e8f4fd; color: #084298; border: 1px solid #b6d4fe; }
    .message.error { background-color: #fdecea; color: #842029; border: 1px solid #f5c2c7; }

    .btn {
      display: inline-block;
      padding: 0.6rem 1rem;
      border-radius: 5px;
      background-color: #f0f0f0;
      color: inherit;
      text-decoration: none;
      border: 1px solid #ccc;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.2s ease;
    }
    .btn:hover { background-color: #e0e0e0; }

    table {
      border-collapse: collapse;
      width: 100%;
      margin-top: 1rem;
    }
    th, td {
      padding: 8px 12px;
      border: 1px solid #ccc;
    }
    th {
      background: #f5f5f5;
      text-align: left;
    }
  </style>
</head>

<body>
  <%- include("navbar") %>
  <div class="container">
    <h1>FHIR Translation Result</h1>
    <% if (mappings && mappings.length > 0) { %>
      <table>
        <tr>
          <th>System</th>
          <th>Code</th>
          <th>Display</th>
        </tr>
        <% mappings.forEach(m => { %>
          <tr>
            <td><%= m.system %></td>
            <td><%= m.code %></td>
            <td><%= m.display %></td>
          </tr>
        <% }) %>
      </table>
    <% } else { %>
      <p>No mappings found.</p>
    <% } %>

    <% if (saved && saved.length > 0) { %>
      <h3>Saved Translations</h3>
      <table>
        <tr>
          <th>System</th>
          <th>Code</th>
          <th>Display</th>
        </tr>
        <% saved.forEach(s => { %>
          <tr>
            <td><%= s.system %></td>
            <td><%= s.code %></td>
            <td><%= s.display %></td>
          </tr>
        <% }) %>
      </table>
    <% } %>

    <br>
    <a href="/terminology" class="btn">⬅ Back to Terminology Service</a>
  </div>
  <%- include('footer') %>
</body>
</html>