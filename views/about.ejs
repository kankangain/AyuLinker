                    <div class="member">
                        <strong>Kankan Gain</strong>
                        🔌Frontend Devoloper<br>
                        <a href="https://www.linkedin.com/in/kankan-gain/" target="_blank">LinkedIn</a>
                    </div>
                    <div class="member">
                        <strong>Rumpi Saha</strong>
                        📚Presentation Lead<br>
                        <a href="https://www.linkedin.com/in/rumpi-saha-a42137216?" target="_blank">LinkedIn</a>
                    </div>
