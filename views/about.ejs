                    </div>
                    <div class="member">
                        <strong>Karishma Bal</strong>
                        🎤Presenter & Speaker<br>
                        <a href="https://www.linkedin.com/in/karishmabal" target="_blank">LinkedIn</a>
                    </div>
                </div>
    </main>
    <!-- Footer -->
    <%- include('footer') %>
        <script src="/js/index-animation.js"></script>
</body>

</html>